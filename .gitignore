# Environment variables (CRITICAL - contains secrets)
.env
.env.local
.env.*.local
*.env

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
ENV/
env/
.venv/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/

# Logs
*.log
logs/

# Data directories (large files)
data/qdrant_storage/
data/redis_data/
data/postgres_data/
data/uploads/
*.db
*.sqlite3

# OS files
.DS_Store
Thumbs.db

# Secrets and credentials
*.pem
*.key
*.crt
credentials.json
secrets.json

# Docker
docker-compose.override.yml

# Node (for frontend)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
