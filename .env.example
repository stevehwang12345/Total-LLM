# =============================================================================
# Total-LLM Environment Configuration
# =============================================================================
# 이 파일을 .env로 복사하여 실제 값을 설정하세요:
#   cp .env.example .env
#
# 주의: .env 파일은 절대 Git에 커밋하지 마세요!
# =============================================================================

# =============================================================================
# 환경 설정
# =============================================================================
# development | staging | production
ENVIRONMENT=development

# API 디버그 모드 (production에서는 반드시 false)
DEBUG=false

# =============================================================================
# 데이터베이스 설정 (PostgreSQL)
# =============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=total_llm
POSTGRES_USER=total_llm
# CRITICAL: 프로덕션에서는 강력한 비밀번호 사용!
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# =============================================================================
# 벡터 데이터베이스 설정 (Qdrant)
# =============================================================================
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=documents

# =============================================================================
# 캐시 설정 (Redis)
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=  # 선택적: Redis 비밀번호

# =============================================================================
# LLM & VLM 설정 (Qwen3.5 통합 - 단일 모델이 텍스트/비전을 모두 처리)
# =============================================================================
VLLM_BASE_URL=http://localhost:9000/v1
LLM_MODEL_NAME=Qwen/Qwen3.5-27B-Instruct-GPTQ-Int4
VLLM_MODEL_NAME=Qwen/Qwen3.5-27B-Instruct-GPTQ-Int4
VLM_BASE_URL=http://localhost:9000/v1
VLM_MODEL_NAME=Qwen/Qwen3.5-27B-Instruct-GPTQ-Int4
VLLM_TEMPERATURE=0.7
VLLM_MAX_TOKENS=4096
VLLM_GPU_DEVICE=1
VLM_SIMULATION_MODE=false

# 분리 배포(선택): VLM만 별도 서버/모델로 분리
# VLM_BASE_URL=http://localhost:9001/v1
# VLM_MODEL_NAME=Qwen/Qwen3-VL-8B-Instruct

# =============================================================================
# 임베딩 모델 설정
# =============================================================================
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DEVICE=cpu

# =============================================================================
# 장치 인증 암호화 키
# =============================================================================
# Fernet 키 생성: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DEVICE_CREDENTIAL_KEY=CHANGE_ME_GENERATE_NEW_FERNET_KEY

# =============================================================================
# JWT 인증 설정
# =============================================================================
# 비밀 키 생성: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_GENERATE_NEW_SECRET_KEY
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# =============================================================================
# API 서버 설정
# =============================================================================
API_HOST=0.0.0.0
API_PORT=9002

# CORS 허용 오리진 (콤마로 구분)
# production에서는 특정 도메인만 지정: https://yourdomain.com
CORS_ORIGINS=http://localhost:9004,http://localhost:3000

# =============================================================================
# Kafka 설정 (선택적)
# =============================================================================
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=security.alarms
KAFKA_GROUP_ID=vllm-security-monitoring

# =============================================================================
# 스토리지 경로
# =============================================================================
DATA_PATH=/app/data
UPLOAD_PATH=/app/data/uploads
LOG_PATH=/app/logs
REPORT_PATH=/app/data/reports

# =============================================================================
# 모니터링 (선택적)
# =============================================================================
# SENTRY_DSN=https://your-sentry-dsn
# SENTRY_ENVIRONMENT=development
